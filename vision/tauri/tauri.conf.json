{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "mneme vision",
  "version": "0.3.2",
  "identifier": "dev.mneme.vision",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "bun server.ts",
    "beforeBuildCommand": "vite build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mneme vision",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:7777 ws://127.0.0.1:7777; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' http://127.0.0.1:7777 ws://127.0.0.1:7777"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "mneme multi-process daemon — Vision",
    "longDescription": "14 view modes + Command Center for the mneme codebase intelligence daemon."
  }
}
