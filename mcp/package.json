{
  "name": "@mneme/mcp",
  "version": "0.3.2",
  "description": "Mneme MCP server: 48 tools + 8 hooks exposing the mneme supervisor over stdio JSON-RPC.",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "bin": {
    "mneme-mcp": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.0.4",
    "zod": "~3.23.8",
    "zod-to-json-schema": "^3.24.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3"
  },
  "license": "Apache-2.0",
  "author": "Anish Trivedi & Kruti Trivedi"
}
